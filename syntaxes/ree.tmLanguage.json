{
	"name": "Ree Template",
	"scopeName": "text.html.ree",
	"fileTypes": [
		"ree"
	],
	"patterns": [
		{
			"include": "#ree-tags"
		},
		{
			"include": "#alpine-attributes"
		},
		{
			"include": "text.html.basic"
		}
	],
	"repository": {
		"alpine-attributes": {
			"patterns": [
				{
					"comment": "x-data, x-bind, x-show, x-if, x-for, x-model, x-text, x-html, x-ref, x-effect, x-ignore, x-cloak, x-teleport, x-trap",
					"name": "meta.attribute.alpine.ree",
					"match": "\\b(x-[a-zA-Z][a-zA-Z0-9-]*)\\b",
					"captures": {
						"1": {
							"name": "entity.other.attribute-name.alpine.ree"
						}
					}
				},
				{
					"comment": "@event shorthand for x-on:event",
					"name": "meta.attribute.alpine.event.ree",
					"match": "(@[a-zA-Z][a-zA-Z0-9-]*(?:\\.[a-zA-Z0-9-]+)*)",
					"captures": {
						"1": {
							"name": "entity.other.attribute-name.alpine.event.ree"
						}
					}
				},
				{
					"comment": ":prop shorthand for x-bind:prop",
					"name": "meta.attribute.alpine.bind.ree",
					"match": "(?<=[\\s<])(:(?!:)[a-zA-Z][a-zA-Z0-9-]*)",
					"captures": {
						"1": {
							"name": "entity.other.attribute-name.alpine.bind.ree"
						}
					}
				},
				{
					"comment": "Alpine magic properties: $el, $refs, $store, $watch, $dispatch, $nextTick, $data, $id",
					"name": "variable.language.alpine.magic.ree",
					"match": "\\$(el|refs|store|watch|dispatch|nextTick|data|id)\\b"
				},
				{
					"comment": "Highlight Alpine attribute value expressions as embedded JS",
					"name": "meta.attribute.alpine.value.ree",
					"begin": "(?<=(x-[a-zA-Z][a-zA-Z0-9-]*|@[a-zA-Z][a-zA-Z0-9-.]*|:[a-zA-Z][a-zA-Z0-9-]*)\\s*=\\s*)\"",
					"end": "\"",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.string.begin.ree"
						}
					},
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.string.end.ree"
						}
					},
					"contentName": "meta.embedded.expression.alpine.ree",
					"patterns": [
						{
							"include": "source.js"
						}
					]
				},
				{
					"comment": "Single-quoted Alpine attribute value expressions as embedded JS",
					"name": "meta.attribute.alpine.value.ree",
					"begin": "(?<=(x-[a-zA-Z][a-zA-Z0-9-]*|@[a-zA-Z][a-zA-Z0-9-.]*|:[a-zA-Z][a-zA-Z0-9-]*)\\s*=\\s*)'",
					"end": "'",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.string.begin.ree"
						}
					},
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.string.end.ree"
						}
					},
					"contentName": "meta.embedded.expression.alpine.ree",
					"patterns": [
						{
							"include": "source.js"
						}
					]
				}
			]
		},
		"ree-tags": {
			"patterns": [
				{
					"name": "comment.block.ree",
					"begin": "/\\*",
					"end": "\\*/",
					"patterns": []
				},
				{
					"name": "meta.embedded.block.ree",
					"begin": "\\{#",
					"end": "\\}",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.tag.begin.ree"
						}
					},
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.tag.end.ree"
						}
					},
					"patterns": [
						{
							"include": "#ree-keywords"
						},
						{
							"include": "#ree-operators"
						},
						{
							"include": "source.js"
						}
					]
				},
				{
					"name": "meta.embedded.block.ree",
					"begin": "\\{/",
					"end": "\\}",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.tag.begin.ree"
						}
					},
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.tag.end.ree"
						}
					},
					"patterns": [
						{
							"include": "#ree-keywords"
						}
					]
				},
				{
					"name": "meta.embedded.block.ree",
					"begin": "\\{:",
					"end": "\\}",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.tag.begin.ree"
						}
					},
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.tag.end.ree"
						}
					},
					"patterns": [
						{
							"include": "#ree-keywords"
						}
					]
				},
				{
					"name": "meta.embedded.inline.ree",
					"begin": "\\{=",
					"end": "\\}",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.tag.begin.ree"
						}
					},
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.tag.end.ree"
						}
					},
					"patterns": [
						{
							"include": "source.js"
						}
					]
				},
				{
					"name": "meta.embedded.inline.ree",
					"begin": "\\{~",
					"end": "\\}",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.tag.begin.ree"
						}
					},
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.tag.end.ree"
						}
					},
					"patterns": [
						{
							"include": "source.js"
						}
					]
				},
				{
					"name": "meta.embedded.directive.ree",
					"begin": "\\{@",
					"end": "\\}",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.tag.begin.ree"
						}
					},
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.tag.end.ree"
						}
					},
					"patterns": [
						{
							"name": "entity.name.function.ree",
							"match": "[a-zA-Z_][a-zA-Z0-9_-]*(?=\\()"
						},
						{
							"include": "source.js"
						}
					]
				}
			]
		},
		"ree-keywords": {
			"patterns": [
				{
					"name": "keyword.control.ree",
					"match": "\\b(if|else|each|unless|await)\\b"
				},
				{
					"name": "keyword.control.ree",
					"match": "\\b(include|layout)\\b"
				},
				{
					"name": "keyword.control.ree",
					"match": "\\b(as|then|catch)\\b"
				}
			]
		},
		"ree-operators": {
			"patterns": [
				{
					"name": "keyword.operator.ree",
					"match": "=>|\\|\\||&&|!|===|==|!==|!=|<=|>=|<|>|\\?"
				}
			]
		}
	}
}