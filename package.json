{
	"name": "ree-templates",
	"project-type": "utility",
	"displayName": "ree Templates",
	"description": "Syntax highlighting and formatting for REE templates (via reefmt)",
	"version": "1.0.42",
	"publisher": "reepolee",
	"license": "MIT",
	"icon": "icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/reepolee/ree-templates"
	},
	"bugs": {
		"url": "https://github.com/reepolee/ree-templates/issues"
	},
	"homepage": "https://github.com/reepolee/ree-templates#readme",
	"engines": {
		"vscode": "^1.107.0"
	},
	"categories": [
		"Programming Languages",
		"Formatters",
		"Themes"
	],
	"activationEvents": [
		"onLanguage:ree"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"languages": [
			{
				"id": "ree",
				"aliases": [
					"Ree Template",
					"ree"
				],
				"extensions": [
					".ree"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "ree",
				"scopeName": "text.html.ree",
				"path": "./syntaxes/ree.tmLanguage.json"
			}
		],
		"commands": [
			{
				"command": "ree.format",
				"title": "Format ree Template"
			},
			{
				"command": "ree.checkFormatters",
				"title": "ree: Check Formatters (path and version)"
			}
		],
		"configuration": {
			"title": "ree Templates",
			"properties": {
				"ree.formatter": {
					"type": "string",
					"enum": [
						"reefmt",
						"reettier"
					],
					"enumDescriptions": [
						"AST reprinter - re-derives all line breaks from the syntax tree.",
						"Indenter only - preserves the line breaks you write, fixes indentation."
					],
					"default": "reefmt",
					"scope": "resource",
					"description": "Which formatter executable to use for ree templates."
				},
				"ree.reefmtPath": {
					"type": "string",
					"default": "",
					"description": "Path to the reefmt executable. Leave empty to use reefmt from PATH."
				},
				"ree.reettierPath": {
					"type": "string",
					"default": "",
					"description": "Path to the reettier executable. Leave empty to use reettier from PATH."
				},
				"ree.translation.defaultLocale": {
					"type": "string",
					"default": "en",
					"scope": "window",
					"description": "Default locale to display in inline translation decorations and hover."
				}
			}
		},
		"iconThemes": [
			{
				"id": "ree-icons",
				"label": "ree Icons",
				"path": "./themes/ree-icon-theme.json"
			}
		],
		"configurationDefaults": {
			"[ree]": {
				"editor.defaultFormatter": "reepolee.ree-templates"
			},
			"emmet.includeLanguages": {
				"ree": "html"
			}
		}
	},
	"scripts": {
		"compile": "npm run check-types && node esbuild.js",
		"check-types": "tsc --noEmit",
		"watch": "node esbuild.js --watch & tsc --noEmit --watch --project tsconfig.json",
		"vscode:prepublish": "npm run package",
		"package": "npm run check-types && node esbuild.js --production",
		"bundle": "git push && pnpm version patch && git push &&  npm run package && vsce package --no-update-package-json"
	},
	"devDependencies": {
		"@types/node": "25.9.3",
		"@types/vscode": "1.107.0",
		"@vscode/vsce": "3.9.2",
		"esbuild": "0.28.1",
		"typescript": "6.0.3"
	},
	"allowScripts": {
		"keytar@7.9.0": true,
		"esbuild@0.28.1": true,
		"@vscode/vsce-sign@2.0.9": true
	}
}
